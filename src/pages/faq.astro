---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";

const metadata = {
  title: "よくある質問",
  description:
    "秋田南くらし相談室によくお寄せいただくご質問と回答をまとめました。スマホ操作、料金、予約方法など、気になることはお気軽にご確認ください。",
};

const faqCategories = [
  {
    title: "サービスについて",
    items: [
      {
        q: "何をしてくれるの？",
        a: "スマホやパソコンの操作、オンライン手続き、くらしの中の困りごと全般に対応しております。",
      },
      {
        q: "どんなことを頼めばいいの？",
        a: "LINEの使い方、写真の整理、役所手続きなど、具体的な例を挙げさせていただきます。",
      },
      {
        q: "どこまでやってくれるの？",
        a: "基本的な操作説明から複雑な手続きまで、幅広く対応しております。",
      },
      {
        q: "わからないことが多すぎて恥ずかしいのですが…",
        a: "どんな小さなことでも大丈夫です。一緒に進めるスタイルで対応させていただきます。それこそがこのサービスの価値ですので、気楽にご相談ください。",
      },
    ],
  },
  {
    title: "料金・支払いについて",
    items: [
      {
        q: "料金はいくら？",
        a: "30分750円（税込）からのトライアル価格でご案内しております。",
      },
      {
        q: "支払い方法は何がありますか？",
        a: "Squareによるクレジットカード・QRコード決済が基本です。対応が難しい場合は、現金でも対応可能です。",
      },
      {
        q: "前払い？後払い？",
        a: "後払いです。延長の可能性があるため、相談終了後に精算となります。",
      },
      {
        q: "延びたら追加料金はかかるの？",
        a: "30分ごとに750円が追加となりますが、事前にお知らせいたします。",
      },
    ],
  },
  {
    title: "予約・連絡方法について",
    items: [
      {
        q: "どうやって予約すればいいの？",
        a: "双方のために、原則はLINE(LINE電話)や専用フォームからの相談、それも厳しければメール contact@akita-minami-kurashi-soudan.com での相談としております。",
      },
      {
        q: "LINEって何？",
        a: "LINEは、スマートフォンやパソコンで使える無料の通信アプリです。メッセージのやり取り、写真の送信、ビデオ通話などができます。秋田南くらし相談室では、LINEでのご相談をおすすめしております。",
      },
      {
        q: "Discordって何？",
        a: "Discordは、テキストや音声、ビデオを使ったコミュニケーションができる無料のアプリです。もともとゲーム用に作られましたが、現在では様々な場面で利用されています。秋田南くらし相談室でも、Discordでのご相談に対応しております。",
      },
      {
        q: "スマホはなく、携帯電話(ガラケー)しか持っていません。パソコンもありません。ですがいろいろ相談したいです。",
        a: "双方のために、原則はLINE(LINE電話)や専用フォームからの相談、それも厳しければメール contact@akita-minami-kurashi-soudan.com での相談としております。携帯電話でもLINE・専用フォーム・メールは利用できるはずですので、そちらからご連絡ください。",
      },
      {
        q: "予約なしで当日来てもらえる？",
        a: "基本的には予約制ですが、空きがあれば対応させていただきます。",
      },
    ],
  },
  {
    title: "対応エリア・訪問について",
    items: [
      {
        q: "うちまで来てくれるの？",
        a: "羽後町・湯沢市・横手市内は訪問対応しております。",
      },
      {
        q: "交通費はかかる？",
        a: "対応エリア内は無料となっております。",
      },
      {
        q: "他の地域でも来てもらえる？",
        a: "別途ご相談ください。",
      },
    ],
  },
  {
    title: "時間・対応時間について",
    items: [
      {
        q: "何時から何時まで？",
        a: "土・日・祝日 10:00〜19:00（予約制）で対応しております。",
      },
      {
        q: "平日は対応してないの？",
        a: "現在は土日祝のみとなっておりますが、連絡自体はチャット等で順次対応させていただきます。",
      },
      {
        q: "最短でいつ頃来てもらえる？",
        a: "予約状況によりますが、相談の上、予定が空いていれば営業日当日から対応可能です。",
      },
      {
        q: "何分くらいかかる？",
        a: "依頼内容によります。なるべく希望の時間内に収めるよう努めますが、内容に対して時間が少ない場合は、説明を簡略化する可能性がございます。ご了承ください。",
      },
    ],
  },
  {
    title: "セキュリティ・プライバシーについて",
    items: [
      {
        q: "パスワードを見られたりしない？",
        a: "原則、こちらではあなたのパスワードを直接確認したり把握いたしません。",
      },
      {
        q: "個人情報は大丈夫？",
        a: "プライバシーポリシーに準拠しております。",
      },
      {
        q: "家に上がってもらうのは不安…",
        a: "玄関先やカフェでの対応も可能です。ですが、その場で使える手段内での対応になることはご了承ください。",
      },
    ],
  },
  {
    title: "サービス後について",
    items: [
      {
        q: "また同じことを忘れてしまったら？",
        a: "再訪問のご依頼やLINEでのご質問にも対応しております。",
      },
      {
        q: "質問は後からでもできる？",
        a: "後からでも可能です。初回でも継続でも原則サービス料金が発生いたします。予約やお問い合わせそのものに関するご質問は、料金は発生いたしません。",
      },
      {
        q: "おすすめのアプリやサービスはある？",
        a: "ございます。ただし有料か無料か、利用者の技量によって異なりますので、個別にアドバイスさせていただく前提でおります。2026年03月時点で生活に広く役立てるものとしては、Googleが提供するサービスを基礎にされると良いかと考えております。",
      },
    ],
  },
  {
    title: "その他",
    items: [
      {
        q: "家族が勝手に頼んでもいい？",
        a: "本人のご同意が必要です。ただし代理として頼むのではなく、ご家族が依頼者として一緒に説明を受けるという形であれば問題ございません。",
      },
      {
        q: "複数人で相談してもいい？",
        a: "はい、対応可能です。1人の時と同一料金です。ただし、同時進行で話を進めてまいりますので、1人の場合よりも時間がかかる可能性が高くなります。ご了承ください。",
      },
      {
        q: "他の業者と何が違うの？",
        a: "地域密着、顔の見える安心感、生活に直結するようなご提案が可能です。また他の仕事をしておりますため、他の業者よりもご連絡への反応が遅いことでご迷惑をおかけするかもしれませんが、その分相対的にサービス料金を安くすることが可能です。そして何より違うのが、私に気兼ねする必要性が全くないことです。私も生活の中で日々研鑽している身であり、公的サービスでもないからです。",
      },
    ],
  },
];
---

<BaseLayout {metadata}>
  <!-- ヒーローセクション -->
  <section class="py-16 md:py-24 bg-muted">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-6">
        よくある質問
      </h1>
      <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
        ご相談いただく前に、よくお寄せいただくご質問をご確認ください。
      </p>
    </div>
  </section>

  <!-- FAQセクション -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {
        faqCategories.map((category) => (
          <div class="mb-12">
            <h2 class="text-2xl font-bold text-foreground mb-6 pb-2 border-b border-border">
              {category.title}
            </h2>
            <div class="space-y-4">
              {category.items.map((item, index) => (
                <details class="group bg-card rounded-xl border border-border overflow-hidden">
                  <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-muted/50 transition-colors">
                    <span class="text-lg font-semibold text-foreground pr-4">
                      {item.q}
                    </span>
                    <svg
                      class="w-6 h-6 text-muted-foreground group-open:rotate-180 transition-transform flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </summary>
                  <div class="px-6 pb-6 text-muted-foreground leading-relaxed">
                    {item.a}
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CTAセクション -->
  <section class="py-16 md:py-24 bg-primary text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        解決しない場合はお気軽にご相談ください
      </h2>
      <p class="text-xl mb-8 opacity-90">
        LINEまたはGoogleフォームからお気軽にご予約・ご相談ください。
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={siteConfig.contact.lineUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-full bg-[#06C755] text-white hover:bg-[#05B34C] transition-colors"
        >
          <svg class="w-6 h-6 mr-2" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
            ></path>
          </svg>
          LINEで相談する
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-full bg-white text-primary hover:bg-gray-100 transition-colors"
        >
          お問い合わせページへ
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

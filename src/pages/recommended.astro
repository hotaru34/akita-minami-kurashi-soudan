---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";

const metadata = {
  title: "おすすめサービス一覧",
  description:
    "秋田南くらし相談室がおすすめするサービス一覧です。相談中にご紹介するサービスや、日常生活に役立つツールをまとめました。",
};

const categories = [
  {
    title: "総合",
    services: [
      {
        name: "Apple",
        description: "iPhoneやiPadなど、Apple製品の公式サイト。",
        url: "https://www.apple.com/jp/",
        isAffiliate: false,
      },
    ],
  },
  {
    title: "コミュニケーションツール",
    services: [
      {
        name: "LINE",
        description: "スマホやパソコンで無料のメッセージ交換や通話ができる、日本最大級のコミュニケーションツール。",
        url: "https://line.me/ja/",
        isAffiliate: false,
      },
      {
        name: "Discord",
        description: "テキストや音声、ビデオを使ったコミュニケーションができる無料のアプリ。",
        url: "https://discord.com/",
        isAffiliate: false,
      },
      {
        name: "Zoom",
        description: "ビデオ会議・ウェビナーツール。遠くの家族や友人と簡単にビデオ通話ができる。",
        url: "https://zoom.us/",
        isAffiliate: false,
      },
    ],
  },
  {
    title: "SNS",
    services: [
      {
        name: "YouTube",
        description: "動画共有プラットフォーム。料理や教養動画など、様々な動画を視聴できる。",
        url: "https://www.youtube.com/",
        isAffiliate: false,
      },
      {
        name: "X（旧Twitter）",
        description: "短文メッセージを投稿・閲覧できるマイクロブログSNS。",
        url: "https://twitter.com/",
        isAffiliate: false,
      },
      {
        name: "Facebook",
        description: "友人や家族とつながれるソーシャルネットワーキングサービス。",
        url: "https://www.facebook.com/",
        isAffiliate: false,
      },
      {
        name: "Instagram",
        description: "写真や動画を共有できるSNS。",
        url: "https://www.instagram.com/",
        isAffiliate: false,
      },
      {
        name: "TikTok",
        description: "短編動画を投稿・視聴できるSNS。",
        url: "https://www.tiktok.com/",
        isAffiliate: false,
      },
    ],
  },
  {
    title: "AI",
    services: [
      {
        name: "ChatGPT",
        description: "OpenAIが開発したAIチャットボット。文章作成や質問対応など幅広い用途に対応。",
        url: "https://chatgpt.com/",
        isAffiliate: false,
      },
      {
        name: "Claude",
        description: "Anthropicが開発したAIアシスタント。長文の読解や文章作成に強みがある。",
        url: "https://claude.ai/",
        isAffiliate: false,
      },
      {
        name: "Gemini",
        description: "Googleが開発したAIアシスタント。検索や文章作成、画像生成など多機能。",
        url: "https://gemini.google.com/",
        isAffiliate: false,
      },
      {
        name: "NotebookLM",
        description: "Googleが提供するAIノートブック。資料を読み込ませて質問や要約ができる。",
        url: "https://notebooklm.google.com/",
        isAffiliate: false,
      },
      {
        name: "Genspark",
        description: "AI検索エンジン。検索結果をAIが整理して分かりやすく表示してくれる。",
        url: "https://www.genspark.ai/",
        isAffiliate: false,
      },
      {
        name: "Manus",
        description: "AIエージェント。複雑なタスクを自動で実行してくれる。",
        url: "https://manus.im/",
        isAffiliate: false,
      },
    ],
  },
  {
    title: "ネットショッピング",
    services: [
      {
        name: "Amazon",
        description: "世界最大級の通販サイト。幅広い商品が揃っている。",
        url: "https://www.amazon.co.jp/",
        isAffiliate: true,
      },
      {
        name: "楽天",
        description: "日本最大級の通販サイト。楽天ポイントでお得に買い物ができる。",
        url: "https://www.rakuten.co.jp/",
        isAffiliate: true,
      },
      {
        name: "ヤフーショッピング",
        description: "Yahoo!の通販サイト。PayPayポイントが貯まる。",
        url: "https://shopping.yahoo.co.jp/",
        isAffiliate: true,
      },
    ],
  },
  {
    title: "生活",
    services: [
      {
        name: "メルカリ",
        description: "使わなくなったものを簡単に売却できるフリマアプリ。写真を撮るだけで出品できる。",
        url: "https://www.mercari.com/jp/",
        isAffiliate: true,
      },
      {
        name: "PayPay",
        description: "スマホひとつで支払いができる、日本で最も普及しているQRコード決済。",
        url: "https://paypay.ne.jp/",
        isAffiliate: true,
      },
      {
        name: "Audible",
        description: "本を音声で聴けるサービス。目が疲れた時や家事をしながら楽しめる。",
        url: "https://www.audible.co.jp/",
        isAffiliate: true,
      },
    ],
  },
  {
    title: "その他便利",
    services: [
      {
        name: "Canva",
        description: "簡単にデザインを作成できる無料ツール。チラシや名刺作成に便利。",
        url: "https://www.canva.com/ja_jp/",
        isAffiliate: false,
      },
      {
        name: "Adobe Express",
        description: "簡単にデザインや動画編集ができる無料ツール。",

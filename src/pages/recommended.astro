      {
        name: "note",
        description: "ブログや記事を簡単に投稿できるプラットフォーム。",
        url: "https://note.com/",
        isAffiliate: false,
      },
    ],
  },
  {
    title: "事業向け",
    services: [
      {
        name: "Square",
        description: "決済サイト。秋田南くらし相談室でも使っている世界中で利用されている、便利で安心な決済システム。",
        url: "https://squareup.com/i/EEBFDB1551",
        isAffiliate: true,
      },
    ],
  },
  {
    title: "公的サイト",
    services: [
      {
        name: "羽後町公式",
        description: "羽後町の公式サイト。",
        url: "https://www.town.ugo.lg.jp/",
        isAffiliate: false,
      },
      {
        name: "湯沢市公式",
        description: "湯沢市の公式サイト。",
        url: "https://www.city.yuzawa.akita.jp/",
        isAffiliate: false,
      },
      {
        name: "横手市公式",
        description: "横手市の公式サイト。",
        url: "https://www.city.yokote.lg.jp/",
        isAffiliate: false,
      },
      {
        name: "秋田県公式",
        description: "秋田県の公式サイト。",
        url: "https://www.pref.akita.lg.jp/",
        isAffiliate: false,
      },
      {
        name: "金融庁公式",
        description: "金融庁の公式サイト。",
        url: "https://www.fsa.go.jp/",
        isAffiliate: false,
      },
      {
        name: "消費者庁公式",
        description: "消費者庁の公式サイト。",
        url: "https://www.caa.go.jp/",
        isAffiliate: false,
      },
      {
        name: "マイナポータル",
        description: "公的手続きをオンラインで完結できるサービス。",
        url: "https://myna.go.jp/",
        isAffiliate: false,
      },
    ],
  },
];
---

<BaseLayout {metadata}>
  <!-- ヘッダーセクション -->
  <section class="py-16 md:py-24 bg-muted">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-6">
        おすすめサービス一覧
      </h1>
      <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
        相談中にご紹介するサービスの一覧です。
      </p>
    </div>
  </section>

  <!-- PR バナー -->
  <div class="bg-amber-50 border-b border-amber-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <p class="text-center text-amber-800 font-semibold">
        #PR このページにはアフィリエイトリンクが含まれています。
      </p>
    </div>
  </div>

  <!-- カテゴリセクション -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {
        categories.map((category) => (
          <div class="mb-16">
            <h2 class="text-2xl font-bold text-foreground mb-8 pb-2 border-b border-border">
              {category.title}
            </h2>
            <div class="grid md:grid-cols-2 gap-6">
              {category.services.map((service) => (
                <div class="bg-card rounded-2xl p-6 shadow-sm border border-border hover:shadow-md transition-shadow">
                  <div class="flex items-start justify-between mb-3">
                    <h3 class="text-lg font-bold text-foreground">
                      {service.name}
                    </h3>
                    {service.isAffiliate && (
                      <span class="inline-block px-2 py-1 bg-amber-100 text-amber-800 text-xs font-semibold rounded">
                        PR
                      </span>
                    )}
                  </div>
                  <p class="text-muted-foreground text-sm leading-relaxed mb-4">
                    {service.description}
                  </p>
                  <a
                    href={service.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center w-full px-4 py-2 bg-primary text-white font-semibold rounded-lg hover:bg-primary/90 transition-colors"
                  >
                    {service.name}を開く
                    <svg
                      class="w-4 h-4 ml-2"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CTAセクション -->
  <section class="py-16 md:py-24 bg-primary text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        おすすめサービスについてご質問がある場合
      </h2>
      <p class="text-xl mb-8 opacity-90">
        LINEまたはGoogleフォームからお気軽にご相談ください。
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={siteConfig.contact.lineUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-full bg-[#06C755] text-white hover:bg-[#05B34C] transition-colors"
        >
          <svg class="w-6 h-6 mr-2" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
            ></path>
          </svg>
          LINEで相談する
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-full bg-white text-primary hover:bg-gray-100 transition-colors"
        >
          お問い合わせページへ
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
